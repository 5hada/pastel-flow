{
  "manifest_version": 3,
  "name": "Pastel Flow Browser Bridge",
  "version": "0.1.0",
  "description": "Connects Pastel Flow to browser tab groups.",
  "key": "",
  "permissions": [
    "nativeMessaging",
    "storage",
    "tabGroups",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "minimum_chrome_version": "89"
}
